# ===================================
# A주 관심 종목 지능형 분석 시스템 - 환경변수 설정 템플릿
# 이 파일을 .env로 복사한 뒤 실제 설정값을 입력하세요.
# ===================================

# 관심 종목 목록(쉼표로 구분, 상하이/선전 시장 코드 지원)
# 상하이 증권거래소: 600xxx, 601xxx, 603xxx
# 심천 증권거래소: 000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API 키(여러 개 지원, 쉼표로 구분)
# 획득: https://open.anspire.cn/?share_code=QFBC0FYC
# 더 높은 우선순위의 OpenAI 호환 소스가 구성되지 않은 경우 조건이 충족되면 Anspire 대형 모델 게이트웨이 및 뉴스 검색에 키를 재사용할 수 있습니다.
# 다음 게이트웨이 및 모델은 현재 프로젝트의 샘플 구성입니다. 사용 가능 여부는 Anspire 콘솔 및 공식 문서를 참조하세요.
# 샘플 게이트웨이: https://open-gateway.anspire.cn/v6
# 모델 예: Doubao-Seed-2.0-lite(ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro로 재정의 가능)
# 게이트웨이에 지역/버전 차이가 있는 경우 ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6로 덮어쓸 수 있습니다.
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# 데이터 소스 구성
# Tushare Pro 토큰(선택 사항, https://tushare.pro/weborder/#/login?reg=834638에서 획득)
TUSHARE_TOKEN=
# TickFlow API 키(선택 사항, A주 시장 검토 지수를 향상하는 데 사용됩니다. 패키지가 대상 풀 쿼리를 지원하는 경우 시장 통계도 향상될 수 있음)
# TICKFLOW_API_KEY=

# AlphaSift 종목 선별 통합(기본 꺼짐, 일반적으로 Web의 "종목 선별 켜기" 버튼에서 관리)
ALPHASIFT_ENABLED=false
# 스위치 설명:
# - ALPHASIFT_ENABLED는 AlphaSift 종목 선별 흐름에만 영향을 미치며 기존 LITELLM_*/LLM_* 구성을 덮어쓰거나 마이그레이션하거나 정리하지 않습니다.
# - 종료/대체는 단순히 ALPHASIFT_ENABLED를 false로 설정합니다. 기존 provider/base_url/custom 헤더 및 대체 의미 체계는 그대로 유지됩니다.
# - 호환성 기반(운영 및 유지 관리 검증): LiteLLM 공급자 및 OpenAI 호환에 대한 의미론적 설명은 아래 참고 사항을 참조하세요. requirements.txt의 고정된 litellm 버전은 런타임 시 기본적으로 사용됩니다.
ALPHASIFT_INSTALL_SPEC=git+https://github.com/ZhuLinsen/alphasift.git@377049857cc04175dc3cca62121ee41adec6cdb8
# 호환성 지침:
# - ALPHASIFT_INSTALL_SPEC /api/v1/alphasift/install에 대한 명시적 호출에만 해당됩니다. 과거.env 구성은 자동으로 덮어쓰이지 않습니다.
# - 업그레이드 후 새 핀을 사용하려면 이전 `.env`에서 변수를 지우고 종속성을 다시 빌드하고 서비스를 다시 시작하세요. 아니면 직접 3770498로 변경하고... 백엔드를 다시 빌드하세요.
# - `requirements.txt` 및 `src/config.py`를 롤백하지 않고.env에서 이 필드를 변경하는 경우에만 허용 목록 거부(alphasift_install_spec_not_allowed)가 트리거됩니다.
# AlphaSift 시장 전체 스냅샷 소스 우선순위; 구성되지 않은 경우 TUSHARE_TOKEN 구성 여부에 따라 DSA가 자동으로 주입됩니다.
# - 예 TUSHARE_TOKEN: tushare,sina,efinance,akshare_em,em_datacenter
# - 없음 TUSHARE_TOKEN: sina,efinance,akshare_em,em_datacenter
# SNAPSHOT_SOURCE_PRIORITY=tushare,sina,efinance,akshare_em,em_datacenter
# (런타임 시 자동 주입과 일관성을 유지하고 싶다면 그냥 공백으로 두고 이 파일의 값을 수정하지 않는 것이 좋습니다)
# 최신 버전의 AlphaSift는 최신 스냅샷, 일일 기록 및 산업/개념 제공자 캐시를 지원합니다. DSA는 실행 시 기본적으로 data/alphasift 아래의 격리 캐시 디렉터리를 사용합니다.
# 맞춤설정이 필요한 경우 다음 경로를 덮어쓸 수 있습니다. 공백으로 두면 기존 DSA 구성을 덮어쓰지 않습니다.
# ALPHASIFT_DATA_DIR=data/alphasift
# ALPHASIFT_FALLBACK_SNAPSHOT_PATH=data/alphasift/snapshot.last_good.json
# ALPHASIFT_DAILY_HISTORY_CACHE_DIR=data/alphasift/daily_history
# ALPHASIFT_INDUSTRY_PROVIDER_CACHE_DIR=data/alphasift/industry_provider_cache
# AlphaSift 산업/개념 제공자는 기본적으로 꺼져 있습니다. akshare를 켜면 theme_heat, industry heat 및 LLM 컨텍스트에 대한 더 많은 섹션 정보를 제공할 수 있습니다.
# INDUSTRY_PROVIDER=none
# INDUSTRY_PROVIDER_MAX_BOARDS=80
# 단일 LLM 요청 타임아웃(초); AlphaSift 종목 선별은 DSA의 이 설정을 재사용하며, 타임아웃 후에는 LLM이 아닌 정렬 결과로 강등됩니다.
# LLM_TIMEOUT_SEC=60
# AlphaSift LLM 재배치 요청 출력 상한; AlphaSift 주식 선택 재배열에만 영향을 미칩니다(기본값 2048).
# LLM_MAX_TOKENS=2048

# Finnhub(선택 사항, 미국 주식 데이터 소스, 무료 등급 60 calls/min)
# 획득: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage(선택 사항, 미국 주식 데이터 소스, 무료 등급 25 calls/day)
# 획득: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI (선택, 미국 주식/홍콩 주식 거래량 비율, 회전율, PE 및 기타 필드 제공)
# https://open.longbridge.com/에서 획득
# OAuth 2.0(권장): 먼저 scripts/generate_longbridge_oauth_token.py를 실행하여 기본 SDK 토큰 캐시를 생성합니다.
# client_id는 LONGBRIDGE_OAUTH_CLIENT_ID보다 우선순위를 갖습니다. 공백으로 남겨두고 레거시 액세스 토큰이 없으면 LONGBRIDGE_APP_KEY는 다음과 호환됩니다.
# GitHub Actions / Docker는 토큰 캐시 파일을 base64로 만든 다음 LONGBRIDGE_OAUTH_TOKEN_CACHE_B64에 채울 수 있습니다.
# LONGBRIDGE_OAUTH_CLIENT_ID=
# LONGBRIDGE_OAUTH_TOKEN_CACHE_B64=
# 기존 API 키(기존 계정과 호환 가능, 액세스 토큰은 OAuth 액세스 토큰이 아님)
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info 처리 중 캐시 초, 기본값은 86400입니다. 0 = 모든 요청을 가져옵니다.
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# 연결 종료 예외 후 냉각 시간 초, 기본값은 15입니다. 요청 수준에서 빈번한 재연결을 피하기 위해 냉각 기간 동안 Longbridge를 일시적으로 건너뜁니다.
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK 언어는 REPORT_LANGUAGE(zh/en/ko)와 일치합니다. ko는 SDK에 한국어 로케일이 없어 영어(EN)로 폴백됩니다. SDK 로그는 LOG_DIR/longbridge_sdk.log에 기록됩니다.
# 액세스 포인트(REPORT_LANGUAGE와 관련이 없습니다. 다음 기본값을 사용하려면 비워두세요):
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# 커버리지 액세스 포인트; SDK는 내부적으로 LONGPORT_REGION(BRIDGE 제외)로 자동 선택됩니다.
# 코드는 LONGBRIDGE_REGION → LONGPORT_REGION를 자동으로 동기화합니다.
# hk → *.longbridge.com | CN → *.longbridge.cn
# 기타 항목은 Longbridge 시작 문서의 환경 변수 섹션을 참고하세요: https://open.longbridge.com/zh-CN/docs/getting-started
# 야간거래시장 true/false, 기본값은 false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K라인은 실시간 푸시 또는 확인, 기본값은 실시간입니다
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# 접속시 견적패키지 인쇄 여부 (README / 전체가이드와 일치 : 설정하지 않을 경우, 애플리케이션 측 기본값은 off로, 이는 false에 해당)
# SDK 상세 시장 패킷 로그를 활성화하려면 1 / true / yes로 설정합니다(긴 브리지 연결을 디버깅할 때 사용됨)
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# 주식 자동 완성 색인 원격 업데이트(기본적으로 활성화됨, GitHub에 액세스할 수 없을 때 자동으로 로컬 내장 색인으로 다운그레이드됨)
STOCK_INDEX_REMOTE_UPDATE_ENABLED=true

# ===================================
# AI 모델 구성
# ===================================
# 전체 설명: docs/LLM_CONFIG_GUIDE.md
#
# [빠른 시작] API 키를 입력하여 실행하면 시스템이 자동으로 모델을 인식합니다.
#   Anspire Open(원스톱 모델+검색) → ANSPIRE_API_KEYS 입력
#   Gemini(무료한도) → GEMINI_API_KEY를 채워주세요
#   DeepSeek(고가성비) → DEEPSEEK_API_KEY 채우기
#   AIHubmix(집계 플랫폼) → AIHUBMIX_KEY 채우기
#
# [고급] 다중 모델/다중 플랫폼 대체 필요 → 아래의 "다중 채널"을 구성하거나 웹 설정 페이지에서 시각적 관리를 수행합니다.
# ===================================

# 백엔드 생성: 기본 litellm; codex_cli는 명시적으로 옵트인된 로컬 CLI 백엔드(experimental/limited)입니다.
# 로컬 CLI 백엔드는 오프라인 모델과 동일하지 않습니다. CLI 뒤의 서비스는 분석 프롬프트를 처리하고 초안을 보고할 수 있습니다.
GENERATION_BACKEND=litellm
# 백엔드 수준 대체; local.env null 값은 백엔드 수준 폴백을 비활성화하고, litellm -> litellm은 no-op로 구문 분석됩니다.
# 기본적으로 GitHub Actions 워크플로는 이 변수가 구성되지 않은 경우 litellm을 명시적으로 사용합니다. Actions에서 폴백을 비활성화하려는 경우 이를 기본 백엔드로 설정하여 자체 무작동(no-op)을 구현할 수 있습니다.
GENERATION_FALLBACK_BACKEND=litellm
# 로컬 CLI 백엔드 실행의 상한입니다. 최대 시간 초과는 3600이고, 최대 출력은 33554432바이트이며, 최대 동시성은 16/4입니다.
GENERATION_BACKEND_TIMEOUT_SECONDS=300
GENERATION_BACKEND_MAX_OUTPUT_BYTES=1048576
GENERATION_BACKEND_MAX_CONCURRENCY=1
LOCAL_CLI_BACKEND_MAX_CONCURRENCY=1
# 에이전트 채팅 백엔드; 웹 설정 페이지에는 auto/litellm만 표시되며, 직접 작성한 codex_cli는 지원되지 않는 도구 호출 진단을 반환합니다.
AGENT_GENERATION_BACKEND=auto

# --- API 키(한 개만 입력) ---

# 제미니 (https://aistudio.google.com）)
# GEMINI_API_KEY=
# 다중 키 로드 밸런싱: GEMINI_API_KEYS=key1,key2,key3

# 딥시크(https://platform.deepseek.com）)
# 기본값과 호환 가능: DEEPSEEK_API_KEY만 입력할 때는 계속 deepseek-chat을 사용하고 로그에 메시지가 표시되면 deepseek-v4-flash로 마이그레이션합니다.
# DEEPSEEK_API_KEY=

# AIHubmix 집계(https://aihubmix.com/?aff=CfMq）)
# 하나의 Key로 GPT/Claude/Gemini/GLM/Qwen 등 모델을 사용할 수 있으며 별도 네트워크 우회가 필요 없습니다.
# AIHUBMIX_KEY=

# 인류 클로드 (https://console.anthropic.com）)
# ANTHROPIC_API_KEY=

# OpenAI / API와 호환 가능
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # 타사 API 주소(환승역/대리점), 공백으로 두고 공식 주소 사용

# Ollama 로컬 모델(API 키 필요 없음, 권장)
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# 또는 채널 모드를 사용하세요:
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# 샘플링 온도(0.0-2.0, 기본값 0.7; 0이 가장 확실하고 2가 가장 무작위임)
# 엄격한 온도 호환 소스:
# - Moonshot API / 모델 문서: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot 공식 모델 카드(평가용 기본 온도 = 1.0): https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI 채팅 완료 사양: https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI 호환 사양: https://docs.litellm.ai/docs/providers/openai_compatible
# 현재 저장소 런타임 의존성 제약: litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0(PyPI 사고 버전을 명시적으로 제외, requirements.txt 참조).
# 따라서 kimi-k2.6은 자동으로 1.0/0.6을 사용합니다. GPT-5/o 시리즈와 같은 기본 온도 모델은 API가 요청을 거부하는 것을 방지하기 위해 온도를 생략합니다.
# 호환 플랫폼이 지원되지 않는 매개변수 지우기 오류를 반환하는 경우 런타임은 현재 요청의 매개변수를 수정하고 다시 시도합니다. 성공 전략은 프로세스 내 캐싱만 수행합니다.
# top_p, 존재_페널티, 주파수_페널티, 시드가 "매개변수 지원되지 않음"을 반환하는 경우에도 이 요청 수준에서 수정 및 재시도가 트리거됩니다(LLM_TEMPERATURE는 다시 작성되지 않음).
# 다른 모델과 폴백은 여전히 구성된 LLM_TEMPERATURE를 사용합니다.
# 웹 설정 페이지/데스크톱 가져오기는 LLM_TEMPERATURE를 자동으로 지우거나 다시 쓰지 않습니다. 실제로 요청을 보내기 전에 모델 매개변수를 일시적으로만 조정하세요.
# 메인 모델을 일반 모델로 다시 전환하면 원래 설정한 온도가 자동으로 복원됩니다. 최소 롤백 방법은 이 LLM 매개변수 적응 변경 사항을 롤백하는 것입니다.
# LLM_TEMPERATURE=0.7

# LLM 사용량 원격 측정 메시지 HMAC 구성(선택 사항)
# 기본적으로 공백으로 두면 시스템은 데이터 디렉터리에.llm_usage_hmac_secret을 생성하며 이는 로컬 배포에서 안정적으로 비교할 수 있습니다.
# 사용 메시지 HMAC를 배포 전반에 걸쳐 비교해야 하는 경우에만 동일한 임의 키를 명시적으로 구성합니다. 버전 라벨은 순환 중에 동기적으로 업데이트됩니다.
# 명시적으로 구성할 때 엔트로피가 높은 임의 값(예: openssl rand -hex 32)을 사용하고 실제 키를 버전 관리에 제출하지 마세요.
# LLM_USAGE_HMAC_SECRET=
# LLM_USAGE_HMAC_KEY_VERSION=local-v1

# 제공자 프롬프트 캐시 구성(선택)
# TELEMETRY는 공급자 캐시 사용/진단 기록만 제어합니다. 공급자 암시적 캐시를 제어하지 않습니다.
# HINTS는 프롬프트_cache_key, 캐시_제어, user_id 등과 같은 확인된 공급자별 힌트를 적극적으로 보낼지 여부를 제어합니다. 기본적으로 꺼져 있습니다.
# DIAGNOSTICS_LEVEL 옵션 off/basic/debug; 디버그는 둔감화 진단만 출력하고 원시 프롬프트나 요청 본문은 기록하지 않습니다.
# LLM_PROMPT_CACHE_TELEMETRY_ENABLED=true
# LLM_PROMPT_CACHE_HINTS_ENABLED=false
# LLM_PROMPT_CACHE_DIAGNOSTICS_LEVEL=off

# --- 다중 채널 구성(선택 사항, 웹 설정 페이지에서도 구성 가능) ---
# 각 채널은 base_url / api_key / 모델로 독립적으로 구성되어 다중 키 폴링 및 자동 대체를 지원합니다.
#
# 예: DeepSeek + Gemini 듀얼 채널
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# 예: 사용자 정의 API 엔드포인트(타사 프록시/집계 플랫폼/포워딩 스테이션)
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# 예: Ollama 로컬 모델(API 키가 필요하지 않음)
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# 일반적으로 사용되는 제조업체 템플릿(.env에 복사할 템플릿 선택, 전체 지침은 docs/llm-providers.md 참조)
#
# Anspire Open(LLM 키를 사용한 공유 검색, OpenAI 호환)
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6（예시）
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro（예시 모델）
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite（예시）
#
# AIHubmix 집계 플랫폼(OpenAI 호환)
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI 공식
# LLM_CHANNELS=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek 공식
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini 공식 (공식 계약, Base URL 공백으로 남겨두기)
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude 관계자(공식 협약, 베이스 URL 공란)
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# 키미/문샷(OpenAI 호환)
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# Tongyi Qianwen DashScope(OpenAI 호환)
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# Zhipu GLM(OpenAI 호환)
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax(OpenAI 호환)
# 출처: 공식 OpenAI API 호환 문서 https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM은 openai/<model>을 통해 Chat Completions 호환 Base URL로 라우팅됩니다.
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# Xiaomi MiMo(OpenAI 호환)
# 기본 URL 및 모델명은 MiMo 공식 문서/콘솔을 참조하세요.
# LLM_CHANNELS=mimo
# LLM_MIMO_PROTOCOL=openai
# LLM_MIMO_BASE_URL=
# LLM_MIMO_API_KEY=sk-xxx
# LLM_MIMO_MODELS=mimo-xxx
# LITELLM_MODEL=openai/mimo-xxx
# 참고: 저장소의 기본 daily_analysis workflow는 LLM_MIMO_*를 명시적으로 전달하지 않습니다. 이 예시는 기본적으로 로컬 .env, Docker 또는 self-hosted 스크립트에 적용됩니다. Actions에서 사용하려면 workflow 매핑도 함께 보완하세요.
#
# Volcano Ark / Doubao (OpenAI 호환, 실제 개방 지역에 따라 끝점 조정)
# 출처: 화산방주 온라인 추론/응답 API 문서 https://www.volcengine.com/docs/82379/2121998
# LiteLLM은 openai/<model>을 통해 Chat Completions 호환 Base URL로 라우팅됩니다.
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# 실리콘 기반 흐름 SiliconFlow(OpenAI 호환)
# 출처: 공식 모델 목록 https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter(OpenAI 호환)
# 출처: 공식 모델 API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# 고급: 모델 라우팅 YAML 구성(선택 사항, docs/examples/litellm_config.example.yaml 참조)
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# 검색 엔진 구성(주식 뉴스 얻기용)
# ===================================
# Bocha API 키(중국어 검색 최적화, AI 요약 지원, 다중 지원, 쉼표로 구분)
# 획득: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API 키 (코딩계획 웹검색, 다중지원, 쉼표로 구분)
# 획득: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API 키(여러 개 지원, 쉼표로 구분)
TAVILY_API_KEYS=
# SerpAPI 키(쉼표로 구분된 여러 개 지원)
SERPAPI_API_KEYS=
# Brave Search API 키(여러 개 지원, 쉼표로 구분)
# 획득: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG 인스턴스 주소(쉼표로 구분, 개인 배포 할당량 없음, 형식: settings.yml에서 json을 활성화해야 함)
# GitHub Actions 일일 분석 워크플로는 동일한 이름의 변수 우선순위 및 비밀 대체를 지원합니다. 공용 네트워크 주소는 변수로 구성할 수 있습니다.
# 비워 두면 기본적으로 공개 인스턴스가 searx.space에서 자동으로 가져옵니다. 공개 인스턴스에 액세스하지 않으려면 아래 스위치를 false로 설정할 수 있습니다.
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# 사회 감정 인텔리전스(미국 주식만 해당)
# ===================================
# Reddit / X (Twitter) / api.adanos.org의 Polymarket 감정 데이터
# 미국 주식 시세 표시기(AAPL, TSLA 등)에 대해서만 활성화되고 A-shares/HK 주식에 대해서는 무시됩니다.
# 무료 등급: 250 requests/month | 등록: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 뉴스 적시성 및 분석 필터링 구성
# ===================================
# 뉴스전략창기어 : 초단기(1일) / 단기(3일) / 중형(7일) / 장기(30일)
# 실제 창 = min(정책 창, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# 최대 뉴스 적시성(일). 검색할 때 오래된 정보를 사용하지 않도록 결과를 가까운 미래로 제한하세요.
# NEWS_MAX_AGE_DAYS=3
# 지역 정보/지능 풀이 보관되는 일수입니다. 정보 풀 Intelligence_items만 지워지고 내역 보고서는 영향을 받지 않습니다.
# NEWS_INTEL_RETENTION_DAYS=30
# 단일 RSS/Atom 정보 소스 가져오기 시간 초과(초)
# NEWS_INTEL_FETCH_TIMEOUT_SEC=8
# 각 정보 출처에서 한 번에 수집할 수 있는 최대 항목 수
# NEWS_INTEL_MAX_ITEMS_PER_SOURCE=50
# NewsNow HTTP API 기본 주소 - 외부 종속성 구성
# - 공식 프로젝트 및 배포 가이드: https://github.com/qqhann/newsnow
# - 현재 기본 https://newsnow.busiyi.world는 공개 샘플 인스턴스이며 다음과 같은 위험이 있습니다.
#   * 공식 유지보수나 rate limit 때문에 사용할 수 없을 수 있습니다.
#   * 시연 및 테스트용으로만 안정성이나 데이터 신뢰성이 보장되지 않습니다.
# - 프로덕션 환경에서는 제어 가능성과 안정성을 보장하기 위해 자체 NewsNow 인스턴스를 구축하는 것이 좋습니다.
# - 배포하기 전에 API 계약 호환성을 확인하는 것이 좋습니다(docs/intelligence-sources.md 참조):
#   curl -sS "https://newsnow.busiyi.world/api/s?id=cls-hot" | python -c "import sys, json; data=json.load(sys.stdin); assert isinstance(data.get('items'), list)"
# - 이 구성은 정보 소스 수집 및 정리 동작만 제어하며 LLM/공급자/기본 URL/호환 대체 의미 체계는 변경하지 않습니다.
# NEWSNOW_BASE_URL=https://newsnow.busiyi.world
# 편차율 임계값(%), 편차가 MA5를 초과하면 높은 수준을 추적하지 않는다는 메시지가 표시됩니다. 강한 추세 주식은 자동으로 1.5배로 완화됩니다.
# BIAS_THRESHOLD=5.0

# ===================================
# 에이전트 정책 대화상자 구성(웹 대화상자)
# ===================================
# 에이전트 정책 대화 활성화(기본값은 false, 내부적으로 명명된 스킬)
# AGENT_MODE=true
# 에이전트 메인 모델(선택) : 공백으로 두면 메인 모델이 상속되며, 공급자 접두사가 없으면 openai/<model>에 따라 해결됩니다.
# AGENT_LITELLM_MODEL=
# Agent의 최대 추론 단계 수 상한(기본값이 10인 경우 각 하위 Agent는 자체 기본값에 따라 실행되고, 기본값 10보다 높으면 모든 하위 Agent가 균일하게 이 값을 채택하고, 특정 하위 Agent의 기본값보다 낮으면 상한으로 제한됨)
# AGENT_MAX_STEPS=10
# 기본적으로 정책을 활성화합니다(쉼표로 구분). 구성되지 않은 경우 다음 기본 제공 기본값을 사용합니다.
#
# 내장된 전략 스킬 목록(어떤 조합으로도 결합 가능):
#   Bull_trend — 강세 추세(MA5>MA10>MA20 배열 + 낮은 편차율)
#   ma_golden_cross — 이동 평균 골든 크로스(MA5가 MA10/MA20를 교차함)
#   Volume_breakout — 거래량 돌파(최근 최고가를 돌파한 가격 + 거래량 증가)
#   hot_theme — 인기 주제(정책/업계 핫스팟, 부문 확산 및 개별 주식 상관관계)
#   event_driven — 이벤트 중심(성과, 정책, 주문, 합병 및 인수와 같은 촉매 이벤트)
#   Growth_quality — 성장 품질(수익 이익, ROE, 현금 흐름 및 성장 지속 가능성)
#   Expect_repricing — 예상 재평가(성과/정책/가치 평가 예상 차이 복구 또는 실패)
#   Shrink_pullback — 축소 및 후퇴(이동평균 후퇴 + 거래량 감소, 낮은 후퇴 지점)
#   Bottom_volume — 하단의 거래량 증가(토지 거래량은 토지 가격을 반영, 하단 반전 신호)
#   Dragon_head — 드래곤 헤드 전략(강력한 리더, 추세가 계속해서 상승세를 쫓고 있음)
#   one_yang_3_yin — 1양 3음(주군이 시장을 세척한 후 강력한 반격 패턴)
#   box_oscillation — 상자 진동(범위 내에서 높은 가격에 매도하고 낮은 가격에 구매)
#   chan_theory — Chan Lun (찬 이론: 펜/선분/가운데)
#   wave_theory — 파동 이론(엘리엇 파동 계산)
#   emotion_cycle — 감정 주기(시장 심리는 고점과 저점 사이를 순환합니다)
#
# 공백으로 두면 시스템은 메타데이터에 선언된 주요 기본 전략 스킬을 사용합니다. (내장 기본값은 Bull_trend입니다.)
# AGENT_SKILLS=
#
# 다음과 같이 정책 세트를 수동으로 지정할 수도 있습니다.
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# 내장된 모든 전략을 완전히 활성화합니다(두 가지 쓰기 방법은 동일합니다):
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# 사용자 정의 전략 디렉터리(선택 사항, 사용자 정의 YAML 전략 파일 배치, 환경 변수 이름은 내부 skill 명명을 따릅니다)
# AGENT_SKILL_DIR=./strategies

# 에이전트 아키텍처 모드(기본값은 단일, 다중은 다중 에이전트 오케스트레이션 모드)
# AGENT_ARCH=single

# 다중 에이전트 오케스트레이션 모드(AGENT_ARCH=multi인 경우에만 유효)
# 신속 : 기술분석 → 의사결정 (가장빠름, LLM 호출 약 2건)
# 표준: 기술→지능→의사결정(기본값)
# 전체: 기술→지능→위험 통제→의사결정
# 전문가: 기술→지능→위험 통제→전략적 전문가 평가→의사결정
# AGENT_ORCHESTRATOR_MODE=standard

# 에이전트 실행 제한 시간 예산(초, 0은 꺼짐을 의미함, 단일 에이전트는 전체 주기 예산으로 사용됨, 다중 에이전트는 협업 오케스트레이션 예산으로 사용됨, 기본값은 600)
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# 위험 관리 에이전트가 구매 신호를 거부할 수 있는지 여부(기본적으로 활성화됨)
# AGENT_RISK_OVERRIDE=true

# 메모리 및 보정 시스템(과거 정확도 추적, 신뢰도 자동 조정)
# AGENT_MEMORY_ENABLED=false

# 백테스트 성과에 따라 자동으로 전략 의견에 가중치 부여
# AGENT_SKILL_AUTOWEIGHT=true

# 정책 라우팅 모드 (자동=시장 상황에 따라 자동 선택 / 수동=AGENT_SKILLS 목록 사용)
# AGENT_SKILL_ROUTING=auto

# 주식에 보이는 대화 컨텍스트 압축을 요청합니다(기본값은 꺼짐). 전원을 켜면 사용자에게 표시되는 user/assistant 이력만 압축되며, 동일한 라운드에서 tool/thinking의 투명 전송은 영향을 받지 않습니다.
# AGENT_CONTEXT_COMPRESSION_ENABLED=false
# 압축 전략: 비용=더 많은 토큰 / 균형=균형 / long_context_raw_first=원본 텍스트를 더 많이 유지하는 것을 선호
# AGENT_CONTEXT_COMPRESSION_PROFILE=balanced
# 압축을 트리거하는 과거 토큰 임계값; 현재 프로필 사전 설정을 따르려면 비워 두세요.
# AGENT_CONTEXT_COMPRESSION_TRIGGER_TOKENS=
# 압축 시 마지막 N번의 사용자 라운드와 후속 답변은 원본 텍스트로 유지됩니다. 공백으로 두면 현재 프로필 사전 설정을 따릅니다.
# AGENT_CONTEXT_PROTECTED_TURNS=

# 이벤트 알람 모니터링(스케줄 모드 백그라운드 폴링, 구성된 알림 채널을 트리거한 후 재사용)
# 호환성 참고 사항: 이 섹션에서는 경보 규칙 구성만 추가하고 모델 이름, 공급자, 기본 URL, LiteLLM 또는 LLM 구성 의미를 수정하지 않습니다. 롤백하려면 이벤트 모니터링 구성을 닫거나 제거하기만 하면 됩니다.
# 레거시 JSON는 세 가지 유형의 단일 기호 기본 규칙만 지원합니다. 기술 지표, 옵션 주식, 포지션/계정 및 시장 신호등 규칙에 대해서는 Web/API 알람 센터 구성을 사용하십시오.
# 기존 JSON 지원 규칙:
#   Price_cross — 가격 돌파 기준점, 방향: 위/아래, 필드: 가격
#   가격_변경_퍼센트 — 증가 또는 감소 임계값, 방향: 위/아래, 필드: Change_pct (단위: %)
#   Volume_spike — 볼륨 증폭, 필드: 승수(지난 20일의 평균 볼륨 배수 기준)
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]

# ===================================
# 알림 채널 구성(동시에 여러 구성 가능, 모두 푸시 가능)
# ===================================
#
# [방법 1] 기업 위챗 로봇
# 기업 위챗 그룹 -> 설정 -> 그룹 로봇 -> 추가 -> 웹훅 주소 복사
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# [방법 2] 페이슈 로봇 (둘 중 택1)
#
# 방법 2a — 그룹 맞춤형 로봇 웹훅
# Feishu 그룹 -> 설정 -> 로봇 그룹 -> 로봇 추가 -> 로봇 사용자 정의 -> 웹훅 주소 복사
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# 로봇 보안 설정에서 '서명인증'이 활성화된 경우 비밀번호를 동시에 입력해야 합니다.
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# 로봇 보안 설정에서 '키워드'가 켜져 있는 경우 동일한 키워드를 입력해야 합니다. 시스템은 각 메시지 앞에 자동으로 추가합니다.
# FEISHU_WEBHOOK_KEYWORD=주식일보
#
# 방법 2b — Feishu App Bot 푸시
# Feishu 오픈 플랫폼에서 애플리케이션을 생성하고 im:message 권한을 활성화한 후 게시하세요.
#
# 그룹 채팅 모드(권장): 로봇을 대상 그룹으로 끌어오고 그룹 설정에서 chat_id를 얻습니다.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
#
# 비공개 채팅 모드: 지정된 사용자에게 직접 비공개 메시지를 보냅니다. 사용자의 open_id는 봇 이벤트를 통해 얻거나 API에 문의하세요.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=ou_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_DOMAIN=feishu  # 도메인 이름: feishu(국내 Feishu) / Lark(해외 버전 larksuite.com)
#
# [방법3] 텔레그램 로봇 (2개 항목을 동시에 구성해야 함)
# 1. 텔레그램에서 @BotFather 찾기 -> /newbot -> 봇 토큰 받기
# 2. Chat ID 얻기: @userinfobot에 메시지를 보내거나 https://api.telegram.org/bot<token>/getUpdates 에 접속하세요.
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# [방법 4] 이메일 푸시(2가지 구성만 필요, SMTP가 자동으로 인식)
# QQ 메일함, 163 메일함, Gmail 및 SMTP 인증 코드/기본 인증을 지원하는 기타 메일함 지원
# Outlook/Exchange 테넌트가 OAuth2를 강제하는 경우 현재 버전에서는 아직 지원하지 않습니다.
# 1. 인증 코드 받기(QQ 메일함을 예로 들어): 설정 -> 계정 -> POP3/SMTP 서비스 -> 활성화 -> 인증 코드 받기
# 2. 다음 두 항목을 입력하세요.
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # 선택 사항입니다. 자신에게 보내려면 비워 두세요.
#
# [방법 4 확장] 주식을 그룹 내 다른 우편함으로 보내기 (문제 #268, 선택 사항)
# STOCK_LIST는 실제 분석 범위를 결정합니다. STOCK_GROUP_N는 이메일이 누구에게 전송되는지만 결정합니다. 항상 STOCK_LIST의 하위 집합을 작성하는 것이 좋습니다.
# Telegram / Enterprise WeChat / Webhook 등 다른 채널은 여전히 완전한 STOCK_LIST에 따라 푸시되며 그룹화로 인해 분할되지 않습니다.
# 현재 저장소의 기본 GitHub Actions daily_analysis workflow는 STOCK_GROUP_N / EMAIL_GROUP_N를 자동으로 주입하지 않습니다.
# 따라서 이 기능은 로컬.env, Docker 또는 이러한 변수가 명시적으로 삽입된 기타 런타임 환경에서 작동합니다.
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# [방법 5] 커스텀 웹훅 (여러개 지원, 쉼표로 구분)
# 적용 대상: DingTalk, Discord, Slack, Bark, 자체 구축 서비스 및 POST JSON를 지원하는 기타 웹훅
# 시스템은 자동으로 공통 서비스를 식별하고 해당 형식을 사용합니다.
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # 선택 사항, 인증이 필요한 Webhook에 사용됩니다(헤더 권한 부여: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # Bark/Slack/Discord와 같은 자동 페이로드를 다루는 선택적 전역 JSON 본문 템플릿입니다. $content_json/$title_json 추천
# Docker Compose에서.env를 필기할 때 $$content_json/$$title_json을 적어주세요. 웹 설정 페이지는 자동으로 이스케이프되며 실행 시 단일 $로 복원됩니다.
# WEBHOOK_VERIFY_SSL=true   # 기본 유효성 검사; 이 구성을 읽는 웹후크 스타일 HTTPS 알림 요청에 영향을 미칩니다. 자체 서명된 인증서를 지원하려면 false로 설정하세요. 경고: 비활성화한 후 신뢰할 수 있는 인트라넷에서만 MITM 하이재킹의 위험이 있습니다.
#
# [방법 6] 푸시오버 설정
# 푸시오버 계정 등록 및 애플리케이션 토큰 https://pushover.net/apps/build 생성
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# [방법 6 확장] ntfy 구성
# NTFY_URL에는 https://ntfy.sh/my-topic 또는 https://self-hosted:port/my-topic와 같은 주제 경로가 포함되어야 합니다.
# 시스템은 주제를 구문 분석하고 ntfy JSON를 사용하여 API를 게시하여 Markdown 텍스트를 보냅니다.
# NTFY_URL=
# NTFY_TOKEN=  # 선택 사항, Bearer Token 또는 자체 구축 ntfy 서버가 필요한 항목에 사용됩니다.
#
# [방법 6 확장] Gotify 구성
# GOTIFY_URL는 /message를 포함하지 않는 Gotify 서버 기반 URL입니다. 시스템은 /message를 연결하고 X-Gotify-Key 헤더를 사용하여 토큰을 보냅니다.
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# [방법 7] PushPlus 설정 (국내 푸시 서비스, 권장)
# PushPlus 계정을 등록하고 토큰 https://www.pushplus.plus를 받으세요
# PUSHPLUS_TOKEN=
# 그룹 푸시: 그룹 코드를 입력한 후 해당 그룹의 모든 가입자에게 메시지가 푸시됩니다(일대다).
# PUSHPLUS_TOPIC=
#
# [방법 8] 디스코드 설정
# 두 가지 방법 지원: Webhook(권장, 단순 구성) 및 Bot API(상위 권한)
# 
# 방법 1: Discord Webhook(권장, 봇 계정 필요 없음)
# 디스코드 채널 설정 -> 통합 -> 웹훅 -> 새 웹훅 -> URL 복사
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# 방법 2: Discord Bot API (봇 계정 및 채널 ID 필요)
# 1. 봇 생성: https://discord.com/developers/applications -> 새 애플리케이션 -> 봇 -> 봇 생성
# 2. 봇 토큰 받기: 봇 페이지 -> 토큰 재설정
# 3. 채널 ID 받기: 디스코드에서 개발자 모드 켜기 -> 채널 우클릭 -> ID 복사
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # 기존 변수 이름과 호환되므로 대신 DISCORD_MAIN_CHANNEL_ID 사용을 권장합니다.
# Discord Interaction/Webhook 콜백을 받으려면 서명 확인을 위한 공개 키를 구성해야 합니다.
# 획득 방법: Discord 개발자 포털 -> 일반 정보 -> 공개 키
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# [방법 9] Slack 설정
# 두 가지 방법 지원: Bot API(권장) 및 Incoming Webhook
# 동시에 구성할 경우 텍스트와 이미지가 동일한 채널로 전송되도록 Bot API를 우선적으로 사용하세요.
#
# 방법 1: Slack Bot API(권장, 이미지 업로드 지원)
# 1. Slack 앱 생성: https://api.slack.com/apps -> 새 앱 생성
# 2. 봇 토큰 범위 추가: chat:write, files:write
# 3. 작업 공간에 설치하고 봇 토큰(xoxb-...)을 얻습니다.
# 4. 채널 ID 가져오기: 채널 세부정보 -> 하단의 채널 ID 복사
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# 방법 2: Slack Incoming Webhook(간단한 구성, 이미지 업로드를 지원하지 않음)
# Slack 앱 관리 페이지에서 수신 웹훅 생성 -> URL 복사
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# [방법 10] ServerChan3 설정(중국 내 푸시 서비스, WeChat 푸시 지원)
# ServerChan3 계정을 등록하고 SendKey를 받으세요: https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# [방법 11] AstrBot 구성
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # 선택사항, Bearer 토큰이 필요한 AstrBot Webhook에 사용됨
#
# [고급 설정] 메시지 길이 제한(바이트)
# 한도를 초과할 경우 자동으로 일괄 발송됩니다. 일반적으로 수정이 필요하지 않습니다.
# FEISHU_MAX_BYTES=20000    # Feishu 제한은 약 20KB, 기본값은 20000바이트입니다.
# WECHAT_MAX_BYTES=4000     # Enterprise WeChat 제한은 4096바이트이며 기본값은 4000바이트입니다.
#
# 【이미지 마크다운】(문제 #455)
# 마크다운을 지원하지 않는 채널의 경우 가독성을 높이기 위해 보고서를 이미지로 변환하세요.
# 단일 스톡 푸시 + 사진: MARKDOWN_TO_IMAGE_CHANNELS를 동시에 구성해야 하며 이미지 전송 도구를 설치해야 합니다.
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # 쉼표로 구분됨
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # 이미지 크기가 너무 커지는 것을 방지하기 위해 길이가 이 길이를 초과하면 변환이 발생하지 않습니다.
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(기본값) | markdown-to-file(이모지가 더 좋음, npm i -g markdown-to-file 필요)
# 이미지 변환 도구: wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf) 또는 markdown-to-file
#
# 【알림 라우팅 정책】(Issue #1200 P3)
# 기본적으로 비워두세요. 이 유형의 알림은 구성된 모든 채널에 전송됩니다. 완료되면 나열된 구성된 채널에만 보냅니다.
# 허용되는 값: wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# 【알림 소음 감소 메커니즘】(Issue #1200 P4)
# 기본적으로 모두 꺼져 있습니다. 이는 정적 알림 채널에만 영향을 미치며 로봇이 세션 수신을 트리거하는 데에는 영향을 주지 않습니다.
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # 동일한 안정적인 중복 제거 키는 TTL 내에서 한 번만 전송됩니다. 0은 닫혀있습니다
# NOTIFICATION_COOLDOWN_SECONDS=0       # 동일한 냉각 키는 창 내에서 주파수가 제한됩니다. 0은 닫혀있습니다
# NOTIFICATION_QUIET_HOURS=             # 무음 기간, HH:MM-HH:MM 형식, 자정 지원
# NOTIFICATION_TIMEZONE=                # 아시아/상하이 등의 침묵 기간 시간대; TZ/시스템 현지 시간대를 따르려면 비워 두세요.
# NOTIFICATION_MIN_SEVERITY=            # 정보, 경고, 오류, 중요; 현재 상태를 유지하려면 공백으로 남겨두세요.
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # 예약된 구성; 일일 요약은 현재 전송되지 않습니다.
#
# 【실시간 견적 프리패치】(제455호)
# PREFETCH_REALTIME_QUOTES=true   # false로 설정하면 efinance/akshare_em의 전체 시장 조회를 피할 수 있습니다. tushare는 단일 종목 인터페이스이며 프리패치는 첫 번째 종목만 가져옵니다.

# ===================================
# 단일 종목 푸시 설정(선택 사항)
# ===================================
# 단일 주식 푸시 모드: 주식을 요약한 후 푸시하는 것이 아니라 분석한 후 즉시 푸시합니다.
# SINGLE_STOCK_NOTIFY=false
#
# 보고서 유형: 단순(simplified), 전체(complete), 간략(3-5 문장 요약)
# Docker 환경에서 푸시 내용이 불완전한 경우 전체로 설정할 수 있습니다.
# REPORT_TYPE=simple
# 보고서 출력 언어: zh(중국어, 기본값) / en(영어) / ko(한국어)
# REPORT_LANGUAGE=zh
# 분석 결과 요약만: true로 설정하면 개별 종목 세부정보를 제외하고 요약만 푸시됩니다.
# REPORT_SUMMARY_ONLY=false
# 알림 보고서 하단에는 이번 분석에 사용된 LLM 모델명이 표시됩니다. 숨기려면 false로 설정하세요.
# REPORT_SHOW_LLM_MODEL=true
#
# 보고서 엔진 P0 (Jinja2 / 무결성 검사 / 기록 비교)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# 개별주식분석과 시장리뷰를 결합하여 푸시(기본값은 false)하여 이메일의 양을 줄이고 스팸위험을 줄입니다.
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# 분석 간격 구성(선택)
# ===================================
# 개별 종목 분석과 시장 분석 간의 지연 시간(초)
# Gemini 같은 AI API의 rate limit이 트리거되는 것을 피하기 위해 사용됩니다.
# ANALYSIS_DELAY=0

# AppKey 적용(웹훅 모드와 공유)
DINGTALK_APP_KEY=xxxx
# AppSecret 적용(웹훅 모드와 공유)
DINGTALK_APP_SECRET=xxxx
# 스트림 모드 활성화
DINGTALK_STREAM_ENABLED=false

# Feishu 애플리케이션 구성(App Bot 활성 푸시/Stream Bot/클라우드 문서에 사용되며 그룹 웹후크 푸시를 직접 활성화하지 않음)
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # App Bot 활성 푸시에도 FEISHU_CHAT_ID가 필요합니다. FEISHU_WEBHOOK_URL을 사용하는 것보다 간단한 그룹 푸시가 선호됩니다.
# App Bot이 적극적으로 대상을 푸시합니다. Stream Bot 또는 클라우드 문서에는 필요하지 않습니다.
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
# 장기 연결 모드 활성화
FEISHU_STREAM_ENABLED=false
# Feishu 그룹 로봇 Webhook 보안 설정(Webhook 푸시 모드에서만 사용)
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=주식일보

# 데이터베이스 경로
DATABASE_PATH=./data/stock_analysis.db
# SQLite 쓰기 최적화: WAL는 파일 라이브러리에서 기본적으로 활성화되어 일괄 쓰기 및 동시 쓰기 저장 중에 잠금 경쟁을 줄입니다.
SQLITE_WAL_ENABLED=true
# SQLite 대기 잠금 시간 초과(밀리초)
SQLITE_BUSY_TIMEOUT_MS=5000
# SQLite가 데이터베이스가 잠겨 있는 경우/데이터베이스 테이블이 잠겨 있는 경우 최대 재시도 횟수
SQLITE_WRITE_RETRY_MAX=3
# SQLite 쓰기 재시도 기본 백오프 시간(초, 지수 백오프로 증가)
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# 기록 스냅샷 분석: false로 설정하면 전체 context_snapshot을 유지하지 않습니다.
# Enhanced_context, market_phase_summary, AnalysisContextPack 개요, 진단 및 원시 스냅샷 필드 포함
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# 백테스트 구성(선택사항)
# ===================================
# 백테스팅 활성화 여부(true/false)
BACKTEST_ENABLED=true
# 백테스트 평가창(거래일수)
BACKTEST_EVAL_WINDOW_DAYS=10
# N일 전 백테스트 분석 기록만 기록 (당일/최근 데이터의 불완전한 데이터 방지를 위해)
BACKTEST_MIN_AGE_DAYS=14
# 백테스트 엔진 버전(백테스트 로직 업그레이드 시 결과 구분에 사용)
BACKTEST_ENGINE_VERSION=v1
# 중립 간격 임계값(%), 예를 들어 2는 -2%~+2%가 충격으로 간주됨을 의미합니다.
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === 예약된 작업 구성 ===
# 예약된 작업 활성화 여부(true/false)
SCHEDULE_ENABLED=false
# 일일 실행 시간(HH:MM 형식, 24시간 형식)
SCHEDULE_TIME=18:00
# 다중 실행 목록(쉼표로 구분, 비워둘 경우 SCHEDULE_TIME 사용)
SCHEDULE_TIMES=
# 예약 모드 시작 시 즉시 분석 수행 여부(true/false)
# 명시적으로 설정하지 않으면 예약 모드는 RUN_IMMEDIATELY의 런타임 재정의 의미를 상속하여 이전 구성과 호환됩니다.
SCHEDULE_RUN_IMMEDIATELY=true
# 비타이밍 모드 시작 시 즉시 분석 수행 여부(true/false)
RUN_IMMEDIATELY=true
# 시장 리뷰 활성화 여부(true/false)
MARKET_REVIEW_ENABLED=true
# 개별주식분석에 시장환경 요약 삽입 여부 프롬프트 및 보수적 가드레일 활성화(true/false, 기본 활성화)
DAILY_MARKET_CONTEXT_ENABLED=true
# 시장 리뷰 영역: cn(A주), hk(홍콩 주식), us(미국 주식), 둘 다(모든 시장), hk/us는 홍콩 주식/미국 주식에만 집중하는 사용자에게 적합합니다.
# MARKET_REVIEW_REGION=cn
# 시세평가 지수 상승 및 하락 색상: green_up=녹색 상승, 빨간색 하락(기본값), red_up=빨간색 상승, 녹색 하락
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# 프록시 구성(선택사항)
# ===================================
# 프록시 활성화 여부(true/false, 기본값은 false)
# 로컬 개발 환경에서만 적용되며 GitHub Actions 환경에서는 자동으로 건너뜁니다.
USE_PROXY=false
# 프록시 서버 주소 (기본값 127.0.0.1)
PROXY_HOST=127.0.0.1
# 프록시 서버 포트 (기본값 10809)
PROXY_PORT=10809

# 시스템 구성
# 로그 디렉터리
LOG_DIR=./logs
# 로그 수준 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# LiteLLM 내부 로그 수준(DEBUG/INFO/WARNING/ERROR/CRITICAL, 기본값은 WARNING, 내부 스트리밍/라우팅 세부 정보 문제를 해결할 때 임시로 DEBUG로 설정할 수 있음)
# LITELLM_LOG_LEVEL=WARNING
# 최대 동시 스레드 수(금지 방지를 위해 동시성을 낮게 유지하는 것이 좋습니다)
MAX_WORKERS=3
# 디버깅 로그 활성화 여부
DEBUG=false

# ===================================
# WebUI 구성(선택사항)
# ===================================
# WebUI 기본 시작 여부 (true/false, 기본값 false)
WEBUI_ENABLED=false
# WebUI 수신 주소(기본값 127.0.0.1, 외부 네트워크 액세스를 위해 Docker/클라우드 서버를 0.0.0.0으로 설정해야 함, 자세한 내용은 docs/deploy-webui-cloud.md 참조)
WEBUI_HOST=127.0.0.1
# WebUI 수신 포트(기본값 8000)
WEBUI_PORT=8000
# Web 서비스를 시작하기 전에 프론트엔드를 자동 빌드할지 여부(npm install && npm run build, 기본 true)
WEBUI_AUTO_BUILD=true
# 신뢰할 수 있는 단일 계층 reverse proxy(예: Nginx → App)에서는 X-Forwarded-For를 신뢰해 실제 IP를 얻고, 가장 오른쪽 값을 로그인 rate limit에 사용합니다. 다중 프록시/CDN에서는 rate limit key가 edge proxy IP로 퇴화할 수 있으므로 별도 평가가 필요합니다. 공인망에 직접 노출될 때는 위조 방지를 위해 false를 유지하세요.
# TRUST_X_FORWARDED_FOR=false

# ===================================
# 웹 로그인 인증(선택)
# ===================================
# 비밀번호 보호를 활성화하려면 true로 설정하세요. 최초 방문시 웹페이지에 초기 비밀번호를 설정하세요. 비밀번호는 "시스템 설정 > 비밀번호 변경"에서 수정하실 수 있습니다.
# 비밀번호를 잊은 경우 서버에서 실행: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # 세션 유효 기간(시간)

# ===========================================
# 이미지 인식 주식 코드(설정 페이지의 "이미지에서 추가")
# ===========================================
# 단일 요청 시간 초과 60초; 최대 이미지 크기 5MB
# GEMINI_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY 중 하나 이상 구성 필요(Vision 기능 모델)

# ===========================================
# 데이터 가져오기 프로그램 우선순위 구성
# ===========================================
# 낮은 숫자 = 높은 우선순위(먼저 시도)
# 기본 우선순위: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# 미국 주식의 경우 YFINANCE_PRIORITY=0으로 설정하여 Yahoo Finance를 먼저 사용하세요.

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # eastmoney 호스트에 연결할 수 없는 경우. 기본값: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx 사용자 정의 서버(intranet/deploy용): 내장된 공용 서버 대신 사용자 정의 호스트 사용
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# 또는 여러 서버: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# 예: 미국 주식에 대해 Yahoo Finance 우선순위 지정
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# 실시간 시장 데이터 소스 우선순위 구성
# ===========================================
# 거래량 비율, 회전율, 주가수익률 등 실시간 데이터를 얻는 데 사용됩니다.
# 선택적 데이터 소스(쉼표로 구분, 순서대로 시도):
#   - 텐센트: 텐센트 파이낸스, 거래량 비율/회전율/PE/PB, 단일 주식 조회가 안정적임(첫 번째 선택 권장)
#   - akshare_sina: Sina Finance, 기본 시세, 거래량비는 없지만 매우 안정적
#   - efinance : Dongcai(efinance library), 정량비율이 있고, 전액을 뽑으면 차단되기 쉽습니다.
#   - akshare_em: Dongcai(akshare 라이브러리), 가장 완벽한 데이터, 전체 풀을 쉽게 차단할 수 있음
#   - tushare: Tushare Pro, 2000포인트 필요, 종합 데이터(유료 사용자에게 권장)
#
# 기본 우선순위: tencent > akshare_sina > efinance > akshare_em
# Tushare Pro 고득점 계정이 있는 경우 tushare를 먼저 입력할 수 있습니다.
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# 실시간 시세 활성화 여부 (해제 후 과거 종가 분석 사용)
# ENABLE_REALTIME_QUOTE=true

# 장중 실시간 기술적 측면: 활성화되면 실시간 가격을 사용하여 MA/롱 포지션을 계산합니다(문제 #234). 끄면 어제 종가가 사용됩니다.
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# 칩 배포 활성화 여부(인터페이스가 불안정하므로 클라우드 배포를 위해 끄는 것이 좋습니다)
# ENABLE_CHIP_DISTRIBUTION=true

# 기본 집계 활성화 여부(새로운 P0 기능)
# ENABLE_FUNDAMENTAL_PIPELINE=true

# 기본 집계 성능 및 안정성 매개변수 (단위: 초)
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=3.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: 가져오기 / 리스크 / 환율 강등 설정
# ===========================================
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# Dongcai 인터페이스 패치: Dongcai/Efinance/Akshare Dongcai 인터페이스가 자주 실패하는 경우(RemoteDisconnected, 연결이 닫히는 경우) 켜는 것이 좋습니다.
# 활성화하면 NID 토큰과 임의 User-Agent를 주입해 EastMoney rate limit 가능성을 낮춥니다.
# ENABLE_EASTMONEY_PATCH=false
